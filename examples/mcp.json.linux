// Replace with the absolute path to your cloned boomi-mcp-server repository.
// If 'uv' is not in PATH, use the full path from 'which uv'.
{
    "mcpServers": {
        "boomi": {
            "command": "uv",
            "args": [
                "--directory",
                "/ABSOLUTE/PATH/TO/boomi-mcp-server",
                "run",
                "boomi_mcp_server/server.py"
            ]
        }
    }
}
